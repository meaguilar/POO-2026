<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="800.0"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controlador.JuegoAdivinaNumeroControlador"
            stylesheets="@css/estilos.css"
            styleClass="fondo-juego-adivina">
    <Label layoutX="430" layoutY="35"
           text="¡Apuesta tu suerte!"
           styleClass="titulo-juego-adivina">
    </Label>
    <Label layoutX="500" layoutY="100"
           text="Ingresa un numero de 1 - 100"
           styleClass="subtitulo-juego-adivina">
    </Label>
    <Button fx:id="btnJugar" onAction="#jugar"
            layoutX="450" layoutY="296"
            text="Comprobar"
            styleClass="boton-jugar-adivina">
    </Button>
    <TextField fx:id="txtNumero"
               layoutX="485" layoutY="155"
               styleClass="input-numero"/>
    <Label fx:id="lblResultado"
           layoutX="440" layoutY="470"
           text="Resultado"
           styleClass="resultado-adivina">
    </Label>
</AnchorPane>
