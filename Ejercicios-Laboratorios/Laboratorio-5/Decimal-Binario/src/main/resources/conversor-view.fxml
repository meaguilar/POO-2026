<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane styleClass="root-pane" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ConversorController">

    <VBox alignment="TOP_CENTER" spacing="8.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <padding>
            <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
        </padding>

        <Label styleClass="subtitulo" text="Valor de las conversiones" />
        <Label styleClass="titulo-principal" text="Decimal ↔ Binario" />

        <VBox alignment="CENTER" spacing="5.0">
            <Label styleClass="texto-etiqueta" text="Cantidad:" />
            <TextField fx:id="txtCantidad" maxWidth="200.0" promptText="Ingresa un valor" styleClass="campo-texto" />
        </VBox>

        <Label styleClass="titulo-convertir" text="Convertir" />

        <HBox alignment="CENTER" spacing="12.0">
            <Label styleClass="texto-etiqueta" text="De:" />
            <ComboBox fx:id="cbxDe" prefWidth="130.0" styleClass="combo-box-estilo" />

            <Label styleClass="texto-etiqueta" text="A:" />
            <ComboBox fx:id="cbxA" prefWidth="130.0" styleClass="combo-box-estilo" />
        </HBox>

        <Button onAction="#convertir" prefWidth="180.0" styleClass="btn-convertir" text="Convertir" />

        <VBox alignment="CENTER" spacing="5.0">
            <Label styleClass="resultado-titulo" text="Resultado" />
            <Label fx:id="lblResultado" styleClass="resultado-valor" text="---" />
        </VBox>

        <Button onAction="#limpiar" prefWidth="140.0" styleClass="btn-limpiar" text="Limpiar" />

    </VBox>
</AnchorPane>
