<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="1000.0" stylesheets="@styles.css" styleClass="app-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.RegistroController">
   <children>
      
      <AnchorPane fx:id="paneImagen" prefHeight="200.0" prefWidth="200.0" styleClass="hero-pane" HBox.hgrow="ALWAYS" />
      
      <VBox alignment="CENTER" prefHeight="200.0" prefWidth="200.0" spacing="25.0" styleClass="surface-card" HBox.hgrow="ALWAYS">
         <padding>
            <Insets bottom="40.0" left="50.0" right="50.0" top="40.0" />
         </padding>
         <children>
            
            <Label text="Crear cuenta" styleClass="title-label" />
            
            <VBox alignment="CENTER" maxWidth="450.0" spacing="15.0">
               <children>
                  
                  <TextField fx:id="txtNombreGalerica" prefHeight="40.0" promptText="Nombre de la galería" styleClass="field-input" />
                  
                  <TextField fx:id="txtCorreo" prefHeight="40.0" promptText="Correo electronico" styleClass="field-input" />
                  
                  <ComboBox fx:id="cbxTipoGalerie" maxWidth="1.7976931348623157E308" prefHeight="40.0" promptText="Tipo de galería" styleClass="field-input" />
               
               </children>
            </VBox>
            
            <Button fx:id="btnCrearCuenta" onAction="#manejarRegistro" prefHeight="40.0" prefWidth="180.0" styleClass="primary-button" text="Crear cuenta" />
            
         </children>
      </VBox>
      
   </children>
</HBox>