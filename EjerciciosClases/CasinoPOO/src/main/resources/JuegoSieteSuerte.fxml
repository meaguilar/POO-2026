<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="800.0"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controlador.JuegoSieteSuerteControlador"
            stylesheets="@css/estilos.css"
            styleClass="fondo-juego-siete">

    <Label layoutX="260" layoutY="40"
           text="¡7 de la suerte!"
           styleClass="titulo-siete">
    </Label>
    <Button fx:id="btnJugar" onAction="#jugar"
            layoutX="32" layoutY="200"
            text="Jugar"
            styleClass="boton-jugar-siete">
    </Button>
    <Label fx:id="lblResultado"
           layoutX="253.0" layoutY="241.0"
           text="Label"
           styleClass="resultado-siete">
    </Label>

</AnchorPane>
