<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>

<?import javafx.scene.control.Label?>
<AnchorPane prefHeight="600.0" prefWidth="800.0"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controlador.JuegosControlador"
            stylesheets="@css/estilos.css"
            styleClass="fondo-juegos">
    <Label layoutX="30" layoutY="50"
           text="¿Cuál será tu próxima jugada?"
           styleClass="titulo-juegos">
    </Label>
    <Button fx:id="btnJuego1"
            onAction="#jugarSieteSuerte"
            layoutX="95.0" layoutY="200.0"
            text="7 de la suerte"
            styleClass="boton-juegos">
    </Button>
    <Button fx:id="btnJuego2" onAction="#jugarAdivinaNumero"
            layoutX="95.0" layoutY="320.0"
            text="Adivina el numero"
            styleClass="boton-juegos">
    </Button>
</AnchorPane>
