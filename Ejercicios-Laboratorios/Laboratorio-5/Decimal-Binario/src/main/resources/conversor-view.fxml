<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.ConversorController"
            stylesheets="@styles.css"
            styleClass="root-pane">

    <VBox alignment="TOP_CENTER" spacing="8.0"
          AnchorPane.topAnchor="0.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0">

        <padding>
            <Insets top="15.0" right="20.0" bottom="15.0" left="20.0"/>
        </padding>

        <Label text="Valor de las conversiones" styleClass="subtitulo"/>
        <Label text="Decimal ↔ Binario" styleClass="titulo-principal"/>

        <VBox alignment="CENTER" spacing="5.0">
            <Label text="Cantidad:" styleClass="texto-etiqueta"/>
            <TextField fx:id="txtCantidad"
                       promptText="Ingresa un valor"
                       maxWidth="200.0" styleClass="campo-texto"/>
        </VBox>

        <Label text="Convertir" styleClass="titulo-convertir"/>

        <HBox alignment="CENTER" spacing="12.0">
            <Label text="De:" styleClass="texto-etiqueta"/>
            <ComboBox fx:id="cbxDe" prefWidth="130.0" styleClass="combo-box-estilo"/>

            <Label text="A:" styleClass="texto-etiqueta"/>
            <ComboBox fx:id="cbxA" prefWidth="130.0" styleClass="combo-box-estilo"/>
        </HBox>

        <Button text="Convertir"
                onAction="#convertir"
                prefWidth="180.0"
                styleClass="btn-convertir"/>

        <VBox alignment="CENTER" spacing="5.0">
            <Label text="Resultado" styleClass="resultado-titulo"/>
            <Label fx:id="lblResultado" text="---" styleClass="resultado-valor"/>
        </VBox>

        <Button text="Limpiar"
                onAction="#limpiar"
                prefWidth="140.0"
                styleClass="btn-limpiar"/>

    </VBox>
</AnchorPane>